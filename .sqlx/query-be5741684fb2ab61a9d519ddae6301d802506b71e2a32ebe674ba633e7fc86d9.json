{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT e.id, e.dao_id, e.wallet_address, e.department, e.status, e.commitment_hash, e.joined_at, e.last_payroll_at\n            FROM employees e\n            JOIN salary_commitments s ON s.employee_id = e.id\n            WHERE s.period = $1 AND e.dao_id = $2\n            ",
