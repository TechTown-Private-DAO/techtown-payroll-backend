# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/techtown_payroll

# ─── Cache ───────────────────────────────────────────────────────────────────
# Redis connection string
REDIS_URL=redis://localhost:6379

# ─── Stellar / Soroban ───────────────────────────────────────────────────────
# Soroban-compatible RPC endpoint
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban-rpc.mainnet.stellar.gateway.fm
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Auth ────────────────────────────────────────────────────────────────────
# A long, random secret used to sign JWTs — never share this value
JWT_SECRET=change-me-to-a-long-random-secret

# Token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRATION=3600

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the API listens on
PORT=3000

# Allowed CORS origin (set to your frontend URL)
CORS_ORIGIN=http://localhost:3001
